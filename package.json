{
  "name": "my-curriculum",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*", "apps/*", "scripts"],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "api:dev": "bun --cwd apps/api run dev",
    "translate": "bun scripts/generate-translations.ts",
    "advise": "bun scripts/career-advisor.ts"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
