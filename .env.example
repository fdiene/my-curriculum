# Build-time only (scripts/*), never used by the running API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Metrics endpoint (apps/api) — GitHub API access to compute commit stats
GITHUB_TOKEN=ghp_xxxxx
# Metrics endpoint (apps/api) — repo to query for commit stats, "owner/name" form
GITHUB_REPO=fdiene/my-curriculum

# CORS allow-list (apps/api) — prod value: https://fdiene.com
WEB_ORIGIN=http://localhost:3000

# Build-time (apps/web) — base URL the frontend calls, prod value: https://api.fdiene.com
PUBLIC_API_URL=http://localhost:3000

# Metrics endpoint (apps/api) — displayed uptime percentage, default 99.9
UPTIME_PCT=99.9

# Server port (apps/api), default 3000
PORT=3000
